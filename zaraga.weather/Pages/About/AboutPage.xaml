<?xml version="1.0" encoding="utf-8" ?>
<layouts:LoadingContentPage
    x:Class="zaraga.weather.Pages.About.AboutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:layouts="clr-namespace:zaraga.weather.Layouts"
    xmlns:local="clr-namespace:zaraga.weather.Pages.About"
    x:Name="page"
    ShowLoadingBar="{Binding Source={x:Reference page}, Path=BindingContext.IsLoading}">

    <layouts:LoadingContentPage.BindingContext>
        <local:AboutViewModel />
    </layouts:LoadingContentPage.BindingContext>

    <Shell.TitleView>
        <HorizontalStackLayout>
            <HorizontalStackLayout Grid.Row="0" Grid.Column="0">
                <ImageButton
                    Margin="0,0,5,0"
                    Padding="0"
                    Command="{Binding BindingContext.GoBackCommand, Source={x:Reference page}}"
                    HeightRequest="20"
                    Source="{AppThemeBinding Light=ic_back_black.png,
                                             Dark=ic_back_white.png}"
                    WidthRequest="20" />
                <Label
                    Grid.Column="1"
                    FontAttributes="Bold"
                    Text="Acerca De"
                    TextColor="{AppThemeBinding Light={DynamicResource Primary},
                                                Dark={DynamicResource White}}" />
            </HorizontalStackLayout>
        </HorizontalStackLayout>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout
            Margin="5"
            Padding="5"
            Spacing="10">
            <Label
                Grid.Row="0"
                Grid.Column="0"
                HorizontalOptions="Start"
                HorizontalTextAlignment="Start"
                Style="{DynamicResource Headline}"
                Text="Versión:" />
            <Label
                Grid.Row="0"
                Grid.Column="1"
                Margin="20,0,0,0"
                FontSize="Subtitle"
                Text="1.0.0.0" />

            <Label
                HorizontalOptions="Start"
                HorizontalTextAlignment="Start"
                Style="{DynamicResource Headline}"
                Text="Información climática:">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenBrowserCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <Image
                Margin="20,0,0,0"
                HorizontalOptions="Start"
                Source="weather_api_logo.png"
                WidthRequest="140">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenBrowserCommand}" />
                </Image.GestureRecognizers>
            </Image>

            <Label
                HorizontalOptions="Start"
                HorizontalTextAlignment="Start"
                Style="{DynamicResource Headline}"
                Text="Meteocons:">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenBassDevCommand}" />
                </Label.GestureRecognizers>
            </Label>
            <Image
                Margin="20,0,0,0"
                HeightRequest="70"
                HorizontalOptions="Start"
                Source="bass_dev_logo.png">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenBassDevCommand}" />
                </Image.GestureRecognizers>
            </Image>

        </VerticalStackLayout>
    </ScrollView>

</layouts:LoadingContentPage>