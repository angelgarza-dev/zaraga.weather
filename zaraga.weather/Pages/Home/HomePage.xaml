<?xml version="1.0" encoding="utf-8" ?>
<layouts:LoadingContentPage
    x:Class="zaraga.weather.Pages.Home.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:layouts="clr-namespace:zaraga.weather.Layouts"
    xmlns:local="clr-namespace:zaraga.weather.Pages.Home"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:views="clr-namespace:zaraga.weather.Views"
    x:Name="page"
    ShowLoadingBar="{Binding Source={x:Reference page}, Path=BindingContext.IsLoading}">

    <layouts:LoadingContentPage.BindingContext>
        <local:HomeViewModel />
    </layouts:LoadingContentPage.BindingContext>

    <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsLoading}">
        <Grid RowDefinitions="Auto,*">
            <!--  encabezado  -->
            <Grid
                Grid.Row="0"
                Margin="5"
                ColumnDefinitions="*,Auto">
                <Border Stroke="{StaticResource Gray500}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SearchCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Column="0"
                            Style="{DynamicResource SubHeadline}"
                            Text="{Binding CurrentWeather.location.name}" />
                        <Image
                            Grid.Column="1"
                            HeightRequest="40"
                            Source="{AppThemeBinding Light=ic_search_black.png,
                                                     Dark=ic_search_white.png}" />
                    </Grid>
                </Border>

                <ImageButton
                    Grid.Column="1"
                    Command="{Binding GoToSettingsCommand}"
                    Source="{AppThemeBinding Light=ic_settings_black.png,
                                             Dark=ic_settings_white.png}" />
            </Grid>
            <!--  fin encabezado  -->

            <!--  detalle  -->
            <ScrollView Grid.Row="1" Orientation="Vertical">
                <VerticalStackLayout Padding="10" Spacing="5">

                    <!--  Ultima actualizacion  -->
                    <Label Text="{Binding CurrentWeather.location.region}" />
                    <Label Text="{Binding CurrentWeather.location.country}" />
                    <!--  fin Ultima actualizacion  -->

                    <!--  tiempo local  -->
                    <Border>
                        <VerticalStackLayout>
                            <Grid
                                Padding="2"
                                ColumnDefinitions="Auto,*"
                                RowDefinitions="Auto,Auto">
                                <Image
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    HeightRequest="100"
                                    Source="{Binding CurrentWeather.current.condition.icon, Converter={StaticResource WebImageConverter}}"
                                    VerticalOptions="Center"
                                    WidthRequest="100" />
                                <!--  binding con la referencia por nombre  -->
                                <views:IconView
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    HeightRequest="100"
                                    IconBindable="{Binding BindingContext.CurrentWeather.current.condition.code, Source={x:Reference page}, Converter={StaticResource IconCodeConverter}}"
                                    IsVisible="False"
                                    WidthRequest="100" />


                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource Headline}"
                                    Text="{Binding CurrentWeather.current.temp_c, StringFormat='°c {0}'}" />
                                <!--  TODO: visible si la configuracion de grados farenheight esta activa  -->
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsVisible="False"
                                    Text="{Binding CurrentWeather.current.temp_f, StringFormat='°f {0}'}" />


                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    FontSize="Title"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding CurrentWeather.current.condition.text}" />
                            </Grid>
                            <Label Text="{Binding CurrentWeather.current.last_updated, StringFormat='A las {0:hh:mm tt}'}" />

                            <!--  humedad  -->
                            <HorizontalStackLayout HorizontalOptions="End">
                                <Label
                                    LineHeight="50"
                                    Style="{StaticResource SubHeadline}"
                                    Text="{Binding CurrentWeather.current.humidity, StringFormat='Humedad: {0}'}" />
                                <Image
                                    HeightRequest="40"
                                    IsVisible="False"
                                    Source="humidity.png" />
                                <skia:SKLottieView
                                    Padding="-25"
                                    HeightRequest="50"
                                    IsVisible="True"
                                    RepeatCount="-1"
                                    Source="humidity.json"
                                    WidthRequest="50" />
                            </HorizontalStackLayout>
                            <!--  fin humedad  -->
                        </VerticalStackLayout>
                    </Border>
                    <!--  fin tiempo local  -->

                    <!--  pronostico hora  -->
                    <Label
                        FontSize="Title"
                        Style="{DynamicResource SubHeadline}"
                        Text="Próximas Horas" />
                    <VerticalStackLayout>
                        <CollectionView ItemsSource="{Binding CurrentForecast.forecast.forecastday}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout>
                                        <!--<Label
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        HorizontalOptions="Start"
                                        Text="{Binding date, StringFormat='Fecha: {0:dd-MM-yyyy}'}" />-->

                                        <CollectionView ItemsSource="{Binding hour}">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout
                                                    Orientation="Horizontal"
                                                    SnapPointsAlignment="Start"
                                                    SnapPointsType="Mandatory" />
                                            </CollectionView.ItemsLayout>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="5,0" WidthRequest="130">
                                                        <VerticalStackLayout>
                                                            <Label Text="{Binding time, StringFormat='{0: hh:mm tt}'}" />
                                                            <Image
                                                                HeightRequest="64"
                                                                Source="{Binding condition.icon, Converter={StaticResource WebImageConverter}}"
                                                                WidthRequest="64" />
                                                            <Label
                                                                HeightRequest="40"
                                                                HorizontalTextAlignment="Center"
                                                                LineBreakMode="TailTruncation"
                                                                MaxLines="2"
                                                                Text="{Binding condition.text}"
                                                                VerticalTextAlignment="Start" />
                                                        </VerticalStackLayout>

                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                    <!--  fin pronostico hora  -->

                    <!--  proximos días  -->
                    <Label
                        FontSize="Title"
                        Style="{DynamicResource SubHeadline}"
                        Text="Próximos Días" />
                    <views:LoadingView IsVisible="{Binding ForecastLoading}" />
                    <Border Padding="0">
                        <CollectionView BackgroundColor="{StaticResource Gray300}" ItemsSource="{Binding WeeklyForecast.forecast.forecastday}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                        Margin="0,0,0,1"
                                        ColumnDefinitions="*,*,*"
                                        RowDefinitions="Auto,Auto,Auto,Auto"
                                        Style="{StaticResource GridBackgroundColor}">
                                        <Image
                                            Grid.Row="0"
                                            Grid.RowSpan="3"
                                            Grid.Column="0"
                                            Margin="0,0,10,0"
                                            HeightRequest="70"
                                            Source="{Binding day.condition.icon, Converter={StaticResource WebImageConverter}}"
                                            VerticalOptions="Center" />

                                        <Label
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding date, StringFormat='{0:D}'}" />

                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Text="{Binding day.mintemp_c, StringFormat='Min: {0}'}" />
                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="2"
                                            Text="{Binding day.maxtemp_c, StringFormat='Max: {0}'}" />

                                        <Label
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            HorizontalTextAlignment="Center"
                                            IsVisible="False"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding day.condition.text}" />

                                        <!--<HorizontalStackLayout
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            HorizontalOptions="End">
                                            <Label Text="Detalle" />
                                            <Image
                                                HeightRequest="22"
                                                HorizontalOptions="Center"
                                                Source="{AppThemeBinding Light=ic_arrow_right_black.png,
                                                                         Dark=ic_arrow_right_white.png}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>-->

                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                    <!--  fin proximos días  -->


                    <!--  precipitacion  -->
                    <Label
                        FontSize="Title"
                        Style="{DynamicResource SubHeadline}"
                        Text="Precipitación" />
                    <Border>
                        <VerticalStackLayout>
                            <Label Text="{Binding CurrentWeather.current.precip_mm, StringFormat='Precipitación en ml: {0}'}" />
                            <Label Text="{Binding CurrentWeather.current.precip_in, StringFormat='Precipitación en in: {0}'}" />

                        </VerticalStackLayout>
                    </Border>
                    <!--  fin precipitacion  -->


                    <!--  viento  -->
                    <Label
                        FontSize="Title"
                        Style="{DynamicResource SubHeadline}"
                        Text="Viento" />
                    <Border>
                        <VerticalStackLayout>
                            <Label Text="velocidad" />
                            <Label Text="{Binding CurrentWeather.current.wind_kph, StringFormat='{0} Km'}" />
                            <Label Text="{Binding CurrentWeather.current.wind_mph, StringFormat='{0} mill'}" />
                            <Label Text="direccion en grados de inclinacion" />
                            <Label Text="{Binding CurrentWeather.current.wind_degree}" />
                            <Label Text="direccion del viento" />
                            <Label Text="{Binding CurrentWeather.current.wind_dir}" />

                            <Label Text="velocidad gust" />
                            <Label Text="{Binding CurrentWeather.current.gust_kph, StringFormat='{0} Km'}" />
                            <Label Text="{Binding CurrentWeather.current.gust_mph, StringFormat='{0} mill'}" />
                        </VerticalStackLayout>
                    </Border>
                    <!--  fin viento  -->

                    <!--  Condicion atmosferica  -->
                    <Label
                        FontSize="Title"
                        Style="{DynamicResource SubHeadline}"
                        Text="Condicion atmosferica" />
                    <Border>
                        <VerticalStackLayout>
                            <Label Text="presion del aire en milibares" />
                            <Label Text="{Binding CurrentWeather.current.pressure_mb}" />
                            <Label Text="presion del aire en pulgadas" />
                            <Label Text="{Binding CurrentWeather.current.pressure_in}" />
                            <Label Text="Cobertura de Nubes" />
                            <Label Text="{Binding CurrentWeather.current.cloud, StringFormat='{0}%'}" />

                            <Label Text="Indice UV" />
                            <Label Text="{Binding CurrentWeather.current.uv, StringFormat='{0}'}" />


                            <Label Text="calidad del aire" />
                        </VerticalStackLayout>
                    </Border>
                    <!--  Condicion atmosferica  -->

                    <!--  Astronomia  -->
                    <Label
                        FontSize="Title"
                        Style="{DynamicResource SubHeadline}"
                        Text="Astronomia" />
                    <Border>
                        <VerticalStackLayout>
                            <Label Text="Amanecer" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.sunrise}" />
                            <Label Text="Atardecer" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.sunset}" />
                            <Label Text="Salida Lunar" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.moonrise}" />
                            <Label Text="Ocaso Lunar" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.moonset}" />
                            <Label Text="Fase Lunar" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.moon_phase, Converter={StaticResource MoonPhaseLangConverter}}" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.moon_phase}" />
                            <Label Text="Iluminacion Lunar" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.moon_illumination, StringFormat='{0}%'}" />
                            <Label Text="Sol arriba" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.is_sun_up}" />
                            <Label Text="Luna arriba" />
                            <Label Text="{Binding CurrentAstronomy.astronomy.astro.is_moon_up}" />

                            <!--<views:IconView
                            HeightRequest="100"
                            IconBindable="static_fill_moon_waxing_gibbous.svg"
                            WidthRequest="100" />-->

                            <Image
                                HeightRequest="100"
                                Source="static_fill_moon_waxing_gibbous.png"
                                WidthRequest="100" />

                        </VerticalStackLayout>
                    </Border>
                    <!--  Astronomia  -->

                    <!--  fases de la luna  -->
                    <Label
                        FontSize="Title"
                        IsVisible="False"
                        Style="{DynamicResource SubHeadline}"
                        Text="Fases de la luna" />
                    <Border IsVisible="False">
                        <VerticalStackLayout>
                            <Label Text="Elemento" />
                        </VerticalStackLayout>
                    </Border>
                    <!--  fases de la luna  -->

                </VerticalStackLayout>
            </ScrollView>
            <!--  fin detalle  -->
        </Grid>
    </RefreshView>

</layouts:LoadingContentPage>