<?xml version="1.0" encoding="utf-8" ?>
<layouts:LoadingContentPage
    x:Class="zaraga.weather.Pages.Home.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:expand="clr-namespace:epj.Expander.Maui;assembly=epj.Expander.Maui"
    xmlns:layouts="clr-namespace:zaraga.weather.Layouts"
    xmlns:local="clr-namespace:zaraga.weather.Pages.Home"
    xmlns:models="clr-namespace:zaraga.weather.Models"
    xmlns:skia="clr-namespace:SkiaSharp.Extended.UI.Controls;assembly=SkiaSharp.Extended.UI"
    xmlns:views="clr-namespace:zaraga.weather.Views"
    x:Name="page"
    ShowLoadingBar="{Binding Source={x:Reference page}, Path=BindingContext.IsLoading}">

    <layouts:LoadingContentPage.BindingContext>
        <local:HomeViewModel />
    </layouts:LoadingContentPage.BindingContext>

    <RefreshView Command="{Binding ReloadDataCommand}" IsRefreshing="{Binding IsLoading}">
        <Grid RowDefinitions="Auto,*">
            <!--  encabezado  -->
            <Grid
                Grid.Row="0"
                Margin="5"
                ColumnDefinitions="*,Auto">
                <Border Stroke="{StaticResource Gray500}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SearchCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{DynamicResource SubHeadline}"
                            Text="{Binding CurrentWeather.location.name}" />
                        <Image
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            HeightRequest="35"
                            Source="{AppThemeBinding Light=ic_search_black.png,
                                                     Dark=ic_search_white.png}" />
                        <HorizontalStackLayout
                            Grid.Row="1"
                            Grid.Column="0"
                            Spacing="5">
                            <Label FontSize="Default" Text="{Binding CurrentWeather.location.region}" />
                            <Label Text="," />
                            <Label FontSize="Default" Text="{Binding CurrentWeather.location.country}" />
                        </HorizontalStackLayout>
                    </Grid>
                </Border>

                <ImageButton
                    Grid.Column="1"
                    Command="{Binding GoToSettingsCommand}"
                    HeightRequest="35"
                    Source="{AppThemeBinding Light=ic_settings_black.png,
                                             Dark=ic_settings_white.png}" />
            </Grid>
            <!--  fin encabezado  -->

            <!--  detalle  -->
            <ScrollView
                x:Name="scrol"
                Grid.Row="1"
                Orientation="Vertical">
                <VerticalStackLayout Padding="10" Spacing="5">

                    <!--  tiempo local  -->
                    <Border>
                        <VerticalStackLayout>
                            <Grid
                                Padding="2"
                                ColumnDefinitions="Auto,*"
                                RowDefinitions="Auto,Auto">
                                <views:IconView
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Grid.Column="0"
                                    IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path='CurrentWeather.current.condition.code'}"
                                    IconHeight="100"
                                    IconWidth="100" />
                                <Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Style="{StaticResource Headline}"
                                    Text="{Binding CurrentWeather.current.temp_c, StringFormat='°c {0}'}" />
                                <!--  TODO: visible si la configuracion de grados farenheight esta activa  -->
                                <!--<Label
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    IsVisible="False"
                                    Text="{Binding CurrentWeather.current.temp_f, StringFormat='°f {0}'}" />-->

                                <Label
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    FontSize="Title"
                                    HorizontalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    Text="{Binding CurrentWeather.current.condition.text}" />
                            </Grid>
                            <Label Text="{Binding CurrentWeather.current.last_updated, StringFormat='A las {0:hh:mm tt}'}" />

                        </VerticalStackLayout>
                    </Border>
                    <!--  fin tiempo local  -->

                    <!--  pronostico hora  -->
                    <Label Style="{DynamicResource SubHeadline}" Text="Próximas Horas" />
                    <VerticalStackLayout>
                        <CollectionView ItemsSource="{Binding CurrentForecast.forecast.forecastday}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <VerticalStackLayout>
                                        <!--<Label
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        HorizontalOptions="Start"
                                        Text="{Binding date, StringFormat='Fecha: {0:dd-MM-yyyy}'}" />-->

                                        <CollectionView ItemsSource="{Binding hour}">
                                            <CollectionView.ItemsLayout>
                                                <LinearItemsLayout
                                                    Orientation="Horizontal"
                                                    SnapPointsAlignment="Start"
                                                    SnapPointsType="Mandatory" />
                                            </CollectionView.ItemsLayout>
                                            <CollectionView.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="5,0" WidthRequest="130">
                                                        <VerticalStackLayout>
                                                            <Label Text="{Binding time, StringFormat='{0: hh:mm tt}'}" />
                                                            <views:IconView
                                                                IconBindable="{Binding Path=Text, Source={x:Reference lblItem}}"
                                                                IconHeight="80"
                                                                IconWidth="80" />
                                                            <Label
                                                                x:Name="lblItem"
                                                                IsVisible="False"
                                                                Text="{Binding condition.code}" />
                                                            <Label
                                                                HeightRequest="50"
                                                                HorizontalTextAlignment="Center"
                                                                LineBreakMode="TailTruncation"
                                                                MaxLines="2"
                                                                Text="{Binding condition.text}"
                                                                VerticalTextAlignment="Start" />
                                                        </VerticalStackLayout>

                                                    </Border>
                                                </DataTemplate>
                                            </CollectionView.ItemTemplate>
                                        </CollectionView>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                    <!--  fin pronostico hora  -->

                    <!--  proximos días  -->
                    <Label Style="{DynamicResource SubHeadline}" Text="Próximos Días" />
                    <views:LoadingView IsVisible="{Binding ForecastLoading}" />
                    <Border Padding="0">
                        <CollectionView BackgroundColor="{StaticResource Gray300}" ItemsSource="{Binding WeeklyForecast.forecast.forecastday}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                        Margin="0,0,0,1"
                                        ColumnDefinitions="*,*,*"
                                        RowDefinitions="Auto,Auto,Auto,Auto"
                                        Style="{StaticResource GridBackgroundColor}">
                                        <views:IconView
                                            Grid.Row="0"
                                            Grid.RowSpan="3"
                                            Grid.Column="0"
                                            Margin="0,0,10,0"
                                            IconBindable="{Binding Path=Text, Source={x:Reference lblItem}}"
                                            IconHeight="70"
                                            IconWidth="70" />
                                        <Label
                                            x:Name="lblItem"
                                            IsVisible="False"
                                            Text="{Binding day.condition.code}" />
                                        <Label
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Grid.ColumnSpan="2"
                                            HorizontalTextAlignment="Center"
                                            MaxLines="2"
                                            Text="{Binding date, StringFormat='{0:D}'}" />

                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Text="{Binding day.mintemp_c, StringFormat='Min: {0}'}" />
                                        <Label
                                            Grid.Row="1"
                                            Grid.Column="2"
                                            Text="{Binding day.maxtemp_c, StringFormat='Max: {0}'}" />

                                        <Label
                                            Grid.Row="2"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="3"
                                            HorizontalTextAlignment="Center"
                                            IsVisible="False"
                                            LineBreakMode="WordWrap"
                                            Text="{Binding day.condition.text}" />

                                        <!--<HorizontalStackLayout
                                            Grid.Row="2"
                                            Grid.Column="2"
                                            HorizontalOptions="End">
                                            <Label Text="Detalle" />
                                            <Image
                                                HeightRequest="22"
                                                HorizontalOptions="Center"
                                                Source="{AppThemeBinding Light=ic_arrow_right_black.png,
                                                                         Dark=ic_arrow_right_white.png}"
                                                VerticalOptions="Center" />
                                        </HorizontalStackLayout>-->

                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                    <!--  fin proximos días  -->


                    <expand:Expander Animated="True" HeaderTapped="Expander_HeaderTapped">
                        <expand:Expander.HeaderContent>
                            <Border
                                x:Name="expHeader"
                                Margin="0,20,0,0"
                                Padding="0">
                                <Grid
                                    x:Name="expHeaderContent"
                                    ColumnDefinitions="*,Auto"
                                    RowDefinitions="Auto">
                                    <Label Style="{StaticResource Headline}" Text="Información Adicional" />

                                    <Image
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        HeightRequest="35"
                                        IsVisible="{Binding Path=IsExpanded, Source={RelativeSource AncestorType={x:Type expand:Expander}, AncestorLevel=1}, Converter={StaticResource InverseBoolConverter}}"
                                        Source="{AppThemeBinding Light=ic_arrow_down_black.png,
                                                                 Dark=ic_arrow_down_white.png}" />
                                    <Image
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        HeightRequest="35"
                                        IsVisible="{Binding Path=IsExpanded, Source={RelativeSource AncestorType={x:Type expand:Expander}, AncestorLevel=1}}"
                                        Source="{AppThemeBinding Light=ic_arrow_up_black.png,
                                                                 Dark=ic_arrow_up_white.png}" />
                                </Grid>

                            </Border>
                        </expand:Expander.HeaderContent>

                        <VerticalStackLayout Spacing="5">

                            <!--  humedad  -->
                            <Label Style="{StaticResource SubHeadline}" Text="Humedad" />
                            <BoxView />
                            <Border Padding="0">
                                <Grid ColumnDefinitions="*,*" Style="{StaticResource GridBackgroundBorder}">
                                    <VerticalStackLayout Padding="8,3" Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Covertura" />
                                        <Label
                                            LineHeight="50"
                                            Style="{StaticResource Headline}"
                                            Text="{Binding CurrentWeather.current.humidity, StringFormat='{0}%'}" />
                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Humidity}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Precipitación" />

                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.precip_mm, StringFormat='ml: {0}'}" />
                                        <!--<Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.precip_in, StringFormat='in: {0}'}" />-->

                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.RaindropMeasure}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <!--  fin humedad  -->

                            <!--  viento  -->
                            <Label Style="{DynamicResource SubHeadline}" Text="Viento" />
                            <BoxView />
                            <Border Padding="0">
                                <Grid
                                    ColumnDefinitions="*,*"
                                    RowDefinitions="Auto,Auto"
                                    Style="{StaticResource GridBackgroundBorder}">
                                    <Grid
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Grid.ColumnSpan="2"
                                        Padding="8,3"
                                        ColumnDefinitions="*,*,*"
                                        ColumnSpacing="5"
                                        Style="{StaticResource GridBackgroundColor}">
                                        <VerticalStackLayout Grid.Column="0">
                                            <Label Text="Velocidad" />
                                            <Label Text="{Binding CurrentWeather.current.wind_kph, StringFormat='{0} Km'}" />
                                            <!--<Label Text="{Binding CurrentWeather.current.wind_mph, StringFormat='{0} mill'}" />-->
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1">
                                            <Label Text="Ráfagas" />
                                            <Label Text="{Binding CurrentWeather.current.gust_kph, StringFormat='{0} Km'}" />
                                            <!--<Label Text="{Binding CurrentWeather.current.gust_mph, StringFormat='{0} mill'}" />-->
                                        </VerticalStackLayout>
                                        <views:IconView
                                            Grid.Column="2"
                                            Padding="-10"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Wind}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </Grid>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Inclinación" />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.wind_degree, StringFormat='{0}°'}" />
                                        <views:IconView
                                            Padding="-10"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Windsock}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Dirección" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.wind_dir, Converter={StaticResource WindDirConverter}}" />
                                        <views:IconView
                                            Padding="-10"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Compass}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <!--  fin viento  -->

                            <!--  Astronomia  -->
                            <Label Style="{DynamicResource SubHeadline}" Text="Astronomia" />
                            <BoxView />
                            <Border Padding="0">
                                <Grid
                                    ColumnDefinitions="*,*"
                                    RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                    Style="{StaticResource GridBackgroundBorder}">
                                    <VerticalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Amanecer" />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentAstronomy.astronomy.astro.sunrise}" />
                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Sunrise}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Atardecer" />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentAstronomy.astronomy.astro.sunset}" />
                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Sunset}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Puesta Lunar" />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentAstronomy.astronomy.astro.moonset}" />
                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Moonset}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">

                                        <Label Text="Salida Lunar" />
                                        <Label
                                            IsVisible="True"
                                            Style="{StaticResource Headline}"
                                            Text="{Binding CurrentAstronomy.astronomy.astro.moonrise}">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding CurrentAstronomy.astronomy.astro.moonrise}"
                                                    TargetType="Label"
                                                    Value="No moonrise">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Label
                                            IsVisible="False"
                                            Style="{StaticResource Headline}"
                                            Text="Sin Salida">
                                            <Label.Triggers>
                                                <DataTrigger
                                                    Binding="{Binding CurrentAstronomy.astronomy.astro.moonrise}"
                                                    TargetType="Label"
                                                    Value="No moonrise">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Moonrise}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Fase Lunar" />
                                        <Label
                                            HeightRequest="64"
                                            MaxLines="2"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentAstronomy.astronomy.astro.moon_phase, Converter={StaticResource MoonPhaseLangConverter}}" />

                                        <!--<skia:SKLottieView
                                            Padding="-20"
                                            HeightRequest="50"
                                            IsVisible="True"
                                            RepeatCount="-1"
                                            Source="{Binding MoonImageSource}"
                                            WidthRequest="50" />-->
                                        <views:IconView
                                            Padding="-15"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=MoonImageCode}"
                                            IconHeight="80"
                                            IconWidth="80" />

                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Iluminación" />
                                        <Label
                                            HeightRequest="64"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource Headline}"
                                            Text="{Binding CurrentAstronomy.astronomy.astro.moon_illumination, StringFormat='{0}%'}" />
                                        <views:IconView
                                            Padding="-15"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.StarryNight}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                            <!--  Astronomia  -->

                            <!--  Condicion atmosferica  -->
                            <Label Style="{DynamicResource SubHeadline}" Text="Condición atmosférica" />
                            <BoxView />
                            <Border Padding="0">
                                <Grid
                                    ColumnDefinitions="*,*"
                                    RowDefinitions="Auto,Auto"
                                    Style="{StaticResource GridBackgroundBorder}">
                                    <VerticalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Presión" />
                                        <!--<Label Text="Milibares" />-->
                                        <!--<Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.pressure_mb, StringFormat='mbar: {0}'}" />-->
                                        <!--<Label Text="Pulgadas" />-->
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.pressure_in, StringFormat='in: {0}'}" />

                                        <views:IconView
                                            Padding="-15"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Barometer}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Cobertura" />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.cloud, StringFormat='{0}%'}" />

                                        <views:IconView
                                            Padding="-15"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Overcast}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Indice UV" />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.uv, StringFormat='{0}'}" />

                                        <views:IconView
                                            Padding="-10"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.UVIndex}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Style="{StaticResource VerticalStackBackgroundColor}" />
                                </Grid>
                            </Border>
                            <!--  Condicion atmosferica  -->

                            <!--  calidad de aire  -->
                            <Label Style="{StaticResource SubHeadline}" Text="calidad del aire" />
                            <BoxView />
                            <Border Padding="0">
                                <Grid
                                    ColumnDefinitions="*,*"
                                    RowDefinitions="Auto,Auto,Auto,Auto"
                                    Style="{StaticResource GridBackgroundBorder}">


                                    <VerticalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="CO" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.air_quality.co, StringFormat='{0} ppm'}" />
                                        <views:IconView
                                            Padding="-25"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Pollen}"
                                            IconHeight="90"
                                            IconWidth="100" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="NO2" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.air_quality.no2, StringFormat='{0} ppm'}" />
                                        <views:IconView
                                            Padding="-25"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Pollen}"
                                            IconHeight="90"
                                            IconWidth="100" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="O3" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.air_quality.o3, StringFormat='{0} ppm'}" />
                                        <views:IconView
                                            Padding="-25"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Pollen}"
                                            IconHeight="90"
                                            IconWidth="100" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="SO2" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.air_quality.so2, StringFormat='{0} ppm'}" />
                                        <views:IconView
                                            Padding="-25"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Pollen}"
                                            IconHeight="90"
                                            IconWidth="100" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="PM2.5" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.air_quality.pm2_5, StringFormat='{0} ppm'}" />
                                        <views:IconView
                                            Padding="-25"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Pollen}"
                                            IconHeight="90"
                                            IconWidth="100" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="PM10" />
                                        <Label
                                            HorizontalOptions="Center"
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource SubHeadline}"
                                            Text="{Binding CurrentWeather.current.air_quality.pm10, StringFormat='{0} ppm'}" />
                                        <views:IconView
                                            Padding="-25"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=WeatherIndicators.Pollen}"
                                            IconHeight="90"
                                            IconWidth="100" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="EPA de EU." />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.air_quality.usepaindex}" />

                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=EpaImageCode}"
                                            IconHeight="80"
                                            IconWidth="80" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Padding="8,3"
                                        Style="{StaticResource VerticalStackBackgroundColor}">
                                        <Label Text="Defra de UK." />
                                        <Label Style="{StaticResource Headline}" Text="{Binding CurrentWeather.current.air_quality.gbdefraindex}" />
                                        <views:IconView
                                            Padding="-20"
                                            IconBindable="{Binding x:DataType='local:HomeViewModel', Source={RelativeSource AncestorType={x:Type local:HomeViewModel}}, Path=DefraImageCode}"
                                            IconHeight="80"
                                            IconWidth="80" />

                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                            <!--  fin calidad de aire  -->

                            <!--  otros  -->
                            <Border IsVisible="false">
                                <VerticalStackLayout>
                                    <Label Text="Sol arriba" />
                                    <Label Text="{Binding CurrentAstronomy.astronomy.astro.is_sun_up}" />
                                    <Label Text="Luna arriba" />
                                    <Label Text="{Binding CurrentAstronomy.astronomy.astro.is_moon_up}" />

                                    <!--  ejemplos de como implementar la vista de imagenes que cambia segun la configuracion  -->
                                    <!--<views:IconView
                                        HeightRequest="100"
                                        IconBindable="static_fill_moon_waxing_gibbous.svg"
                                        WidthRequest="100" />-->
                                    <Image
                                        HeightRequest="100"
                                        Source="static_fill_moon_waxing_gibbous.png"
                                        WidthRequest="100" />

                                </VerticalStackLayout>
                            </Border>
                            <!--  fin otros  -->

                        </VerticalStackLayout>
                    </expand:Expander>

                </VerticalStackLayout>
            </ScrollView>
            <!--  fin detalle  -->
        </Grid>
    </RefreshView>

</layouts:LoadingContentPage>