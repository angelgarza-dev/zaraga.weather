<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="zaraga.weather.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:about="clr-namespace:zaraga.weather.Pages.About"
    xmlns:favorites="clr-namespace:zaraga.weather.Pages.Favorites"
    xmlns:home="clr-namespace:zaraga.weather.Pages.Home"
    xmlns:icons="clr-namespace:zaraga.weather.Pages.Icons"
    xmlns:local="clr-namespace:zaraga.weather"
    xmlns:settings="clr-namespace:zaraga.weather.Pages.Settings"
    Title="zaraga.weather"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab
            Title="Inicio"
            Icon="ic_pin_white.png"
            Shell.TabBarIsVisible="False">
            <ShellContent ContentTemplate="{DataTemplate home:HomePage}" Route="HomePage" />
        </Tab>
        <Tab
            Title="Favoritos"
            Icon="ic_favorite_white.png"
            Shell.TabBarIsVisible="False">
            <ShellContent ContentTemplate="{DataTemplate favorites:FavoritesPage}" Route="FavoritesPage" />
        </Tab>
        <Tab
            Title="App"
            Icon="ic_settings_white.png"
            Shell.TabBarIsVisible="False">
            <ShellContent
                Title="Ajustes"
                ContentTemplate="{DataTemplate settings:SettingsPage}"
                Route="SettingsPage" />
            <ShellContent
                Title="Acerca De"
                ContentTemplate="{DataTemplate about:AboutPage}"
                Route="AboutPage" />
            <ShellContent
                Title="Iconos"
                ContentTemplate="{DataTemplate icons:IconsPage}"
                Route="IconsPage" />
        </Tab>
    </TabBar>

</Shell>
